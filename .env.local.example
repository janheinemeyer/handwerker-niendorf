# Supabase — server-side only. Copy to .env.local and fill in.
# Find these under: Supabase Dashboard → Project Settings → API.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security. Keep it server-side,
# never expose it to the browser, never commit .env.local.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard (/admin) — also set these in Vercel.
# ADMIN_PASSWORD: the login password. ADMIN_SESSION_SECRET: a long random string
# used to sign the session cookie (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
