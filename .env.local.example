# Supabase — server-side only. Copy to .env.local and fill in.
# Find these under: Supabase Dashboard → Project Settings → API.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security. Keep it server-side,
# never expose it to the browser, never commit .env.local.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard (/admin) — also set these in Vercel.
# ADMIN_PASSWORD: the login password. ADMIN_SESSION_SECRET: a long random string
# used to sign the session cookie (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Lead notifications via Telegram — also set these in Vercel. New leads are
# pushed to your chat (instant notification + durable record). Both optional: if
# unset, leads still validate, store in Supabase when configured, and (only as a
# last resort) fall back to a server log.
#   1. Create a bot: message @BotFather → /newbot → copy the token below.
#   2. Get your chat id: send your bot any message, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates and read
#      result[].message.chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
